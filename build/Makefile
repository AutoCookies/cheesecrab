# Build rule for target.
cheese-lookup: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 cheese-lookup
.PHONY : cheese-lookup

# fast build rule for target.
cheese-lookup/fast:
	$(MAKE) $(MAKESILENT) -f examples/lookup/CMakeFiles/cheese-lookup.dir/build.make examples/lookup/CMakeFiles/cheese-lookup.dir/build
.PHONY : cheese-lookup/fast

