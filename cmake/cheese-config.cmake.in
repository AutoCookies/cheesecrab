set(CHEESE_VERSION      @CHEESE_INSTALL_VERSION@)
set(CHEESE_BUILD_COMMIT @CHEESE_BUILD_COMMIT@)
set(CHEESE_BUILD_NUMBER @CHEESE_BUILD_NUMBER@)
set(CHEESE_SHARED_LIB   @BUILD_SHARED_LIBS@)

@PACKAGE_INIT@

set_and_check(CHEESE_INCLUDE_DIR "@PACKAGE_CHEESE_INCLUDE_INSTALL_DIR@")
set_and_check(CHEESE_LIB_DIR     "@PACKAGE_CHEESE_LIB_INSTALL_DIR@")
set_and_check(CHEESE_BIN_DIR     "@PACKAGE_CHEESE_BIN_INSTALL_DIR@")

find_package(ggml REQUIRED HINTS ${CHEESE_LIB_DIR}/cmake)

find_library(cheese_LIBRARY cheese
    REQUIRED
    HINTS ${CHEESE_LIB_DIR}
    NO_CMAKE_FIND_ROOT_PATH
)

add_library(cheese UNKNOWN IMPORTED)
set_target_properties(cheese
    PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${CHEESE_INCLUDE_DIR}"
        INTERFACE_LINK_LIBRARIES "ggml::ggml;ggml::ggml-base;"
        IMPORTED_LINK_INTERFACE_LANGUAGES "CXX"
        IMPORTED_LOCATION "${cheese_LIBRARY}"
        INTERFACE_COMPILE_FEATURES c_std_90
        POSITION_INDEPENDENT_CODE ON)

check_required_components(Cheese)
